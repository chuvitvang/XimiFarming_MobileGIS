<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp"
    app:strokeWidth="0.5dp"
    app:strokeColor="@color/divider"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/txt_log_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12/03/2026 - 15:30"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_muted" />

            <TextView
                android:id="@+id/txt_log_index"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="ExG: +0.45"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/health_good" />
        </RelativeLayout>

        <TextView
            android:id="@+id/txt_log_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lá xanh đều, không phát hiện sâu bệnh. Cây ra cành mới khỏe mạnh."
            android:textSize="14sp"
            android:textColor="@color/text_main" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
