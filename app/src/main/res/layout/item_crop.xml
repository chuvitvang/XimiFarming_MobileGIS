<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp"
    app:strokeWidth="0.5dp"
    app:strokeColor="@color/divider"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Plant Icon/Avatar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#e8f5e9"
            app:strokeWidth="0dp"
            android:layout_marginEnd="12dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                app:srcCompat="@android:drawable/ic_menu_myplaces"
                app:tint="@color/primary" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_crop_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cây Bưởi Da Xanh #3"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_main" />

            <TextView
                android:id="@+id/txt_crop_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loại: Cây ăn quả | Trồng ngày: 12/03/2026"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_crop_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Khỏe mạnh"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/health_good" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
