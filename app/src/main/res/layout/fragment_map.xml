<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Google Map Fragment -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Branding Panel -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/top_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/glass_overlay">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/dot_green"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bản đồ GIS Cây trồng"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:textSize="15sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Map Tools Side Layout -->
    <LinearLayout
        android:id="@+id/tools_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Draw Plot Tool Button -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_draw_plot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="Chia lô đất"
            app:srcCompat="@android:drawable/ic_menu_edit"
            app:backgroundTint="@color/white"
            app:tint="@color/primary"
            app:fabSize="normal" />

        <!-- Add Crop Tool Button -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_add_crop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="Thêm cây trồng"
            app:srcCompat="@android:drawable/ic_input_add"
            app:backgroundTint="@color/white"
            app:tint="@color/secondary"
            app:fabSize="normal" />

        <!-- Toggle GEE NDVI Layer -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_toggle_gee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Lớp phủ GEE NDVI"
            app:srcCompat="@android:drawable/ic_menu_gallery"
            app:backgroundTint="@color/white"
            app:tint="@color/accent"
            app:fabSize="normal" />
    </LinearLayout>

    <!-- Map Selection Info Panel (Appears when clicking on a plot or crop) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/selection_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/txt_selection_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lô Đất số 1"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_main" />

                <TextView
                    android:id="@+id/txt_selection_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="TỐT"
                    android:textStyle="bold"
                    android:textColor="@color/health_good"
                    android:textSize="14sp" />
            </RelativeLayout>

            <TextView
                android:id="@+id/txt_selection_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Diện tích: 450 m² | Cây trồng: 12 cây"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_selection_action"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Xem Chi Tiết"
                    android:backgroundTint="@color/primary" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="wrap_content" />

                <Button
                    android:id="@+id/btn_selection_close"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đóng"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Interactive Instruction Toast Overlay (e.g. "Chạm vào bản đồ để vẽ") -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/instruction_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#e01b5e20"
        app:strokeWidth="0dp">

        <TextView
            android:id="@+id/txt_instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Chạm vào bản đồ để vẽ các đỉnh. Nhấn nút OK để lưu."
            android:textColor="@color/white"
            android:textSize="13sp" />
    </com.google.android.material.card.MaterialCardView>

</RelativeLayout>
