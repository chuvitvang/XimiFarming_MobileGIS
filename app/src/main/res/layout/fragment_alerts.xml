<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cảnh báo sức khỏe cây trồng"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/text_main"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Danh sách các lô đất đang có cảnh báo hoặc cần chú ý"
        android:textSize="14sp"
        android:textColor="@color/text_muted"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/txt_empty_alerts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tuyệt vời! Tất cả các lô đất đều khỏe mạnh."
        android:textColor="@color/health_good"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginVertical="36dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_alerts"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</LinearLayout>
