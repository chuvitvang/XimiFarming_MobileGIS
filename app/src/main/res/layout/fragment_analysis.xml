<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Captured Image Preview / Heatmap Overlay -->
    <ImageView
        android:id="@+id/img_captured_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:contentDescription="Xem trước ảnh phân tích" />

    <!-- Scan Line Animation Overlay (Visual effect) -->
    <View
        android:id="@+id/view_scan_line"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@color/primary_light"
        android:visibility="gone" />

    <!-- Top Mode Indicator -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="#cc000000">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Phân tích chỉ số xanh lá ExG"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="14sp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Camera Controls Layout (Bottom) -->
    <LinearLayout
        android:id="@+id/camera_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="24dp"
        android:background="#99000000">

        <ImageButton
            android:id="@+id/btn_gallery"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@android:color/transparent"
            android:contentDescription="Thư viện ảnh"
            app:srcCompat="@android:drawable/ic_menu_gallery"
            app:tint="@color/white" />

        <Space
            android:layout_width="40dp"
            android:layout_height="wrap_content" />

        <!-- Shutter Button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_shutter"
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardCornerRadius="36dp"
            app:cardBackgroundColor="@color/white"
            app:strokeColor="@color/primary"
            app:strokeWidth="4dp">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:background="@drawable/dot_green" />
        </com.google.android.material.card.MaterialCardView>

        <Space
            android:layout_width="40dp"
            android:layout_height="wrap_content" />

        <ImageButton
            android:id="@+id/btn_flash"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@android:color/transparent"
            android:contentDescription="Bật đèn Flash"
            app:srcCompat="@android:drawable/ic_menu_compass"
            app:tint="@color/white" />
    </LinearLayout>

    <!-- Results Panel Overlay -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_analysis_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/camera_controls"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kết quả Phân tích Diệp lục (ExG)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txt_exg_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ExG: +0.45"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/health_good" />

                <Space
                    android:layout_width="16dp"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/txt_exg_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Độ xanh tốt\nCây phát triển bình thường"
                    android:textSize="14sp"
                    android:textColor="@color/text_main" />
            </LinearLayout>

            <TextView
                android:id="@+id/txt_exg_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Chỉ số ExG cao thể hiện mật độ lá xanh đậm, quang hợp tốt. Không phát hiện sâu bệnh hoặc thiếu hụt nitơ."
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <!-- Link to Crop Selection Spinner -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Lưu kết quả cho Cây trồng:"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/spinner_crops"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <Button
                    android:id="@+id/btn_save_analysis"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lưu Kết Quả"
                    android:backgroundTint="@color/primary" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="wrap_content" />

                <Button
                    android:id="@+id/btn_retry_analysis"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chụp lại"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</RelativeLayout>
